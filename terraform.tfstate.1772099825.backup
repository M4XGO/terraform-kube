            "timeout": 180,
            "upgrade_install": null,
            "values": [
              "# ─── Version BLUE (production initiale) ──────────────────────────────────────\n\nreplicaCount: 2\n\nimage:\n  repository: nginx\n  tag: \"1.25-alpine\"\n  pullPolicy: IfNotPresent\n\napp:\n  version: \"v1.0.0\"\n  colorName: \"blue\"\n  colorHex: \"#1a6cf5\"\n  gradientStart: \"#1a6cf5\"\n  gradientEnd: \"#0d3fa3\"\n  message: \"Version 1.0 — Production\"\n  features:\n    - \"Interface de base\"\n    - \"Authentification utilisateur\"\n    - \"Dashboard principal\"\n\nservice:\n  port: 80\n\ningress:\n  enabled: true\n  className: \"nginx\"\n  host: \"demo-app.local\"\n  annotations:\n    nginx.ingress.kubernetes.io/proxy-body-size: \"8m\"\n\n# ─── Argo Rollouts blue/green ─────────────────────────────────────────────────\nrollout:\n  # false = promotion manuelle (idéal pour démo)\n  # true  = promotion auto si l'analyse Prometheus réussit\n  autoPromotionEnabled: false\n  # Délai avant scale-down de l'ancienne version après promotion\n  scaleDownDelaySeconds: 60\n  # Réplicas pour le pod preview (économie de ressources)\n  previewReplicaCount: 1\n\n# ─── AnalysisTemplate Prometheus ─────────────────────────────────────────────\nanalysis:\n  enabled: true\n  prometheusAddress: \"http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090\"\n  # Intervalle entre chaque mesure\n  interval: \"30s\"\n  # Nombre de mesures avant décision\n  count: 3\n  # Taux de succès HTTP minimum (0.0 → 1.0)\n  successRateThreshold: \"0.90\"\n  # Latence P99 maximum en secondes\n  latencyP99Threshold: \"1.0\"\n  # Nombre d'échecs tolérés avant abort automatique\n  failureLimit: 1\n"
            ],
            "verify": false,
            "version": "1.0.0",
            "wait": true,
            "wait_for_jobs": true
          },

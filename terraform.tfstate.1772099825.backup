{
  "version": 4,
  "terraform_version": "1.11.2",
  "serial": 24,
  "lineage": "bb504b50-35c0-b868-c629-450689d06ce3",
  "outputs": {
    "access_commands": {
      "value": "\n════════════════════════════════════════════════\n CLUSTER\n════════════════════════════════════════════════\nkubectl config use-context terraform-kube\nkubectl get nodes -o wide\nminikube status --profile terraform-kube\n\n    ════════════════════════════════════════════════\n MONITORING\n════════════════════════════════════════════════\n# Grafana  — http://localhost:3000\nkubectl port-forward -n monitoring svc/kube-prometheus-stack-grafana 3000:80\n# login: admin / (terraform output -raw grafana_admin_password)\n\n# Prometheus — http://localhost:9090\nkubectl port-forward -n monitoring svc/kube-prometheus-stack-prometheus 9090:9090\n\n# Alertmanager — http://localhost:9093\nkubectl port-forward -n monitoring svc/kube-prometheus-stack-alertmanager 9093:9093\n\n        ════════════════════════════════════════════════\n ARGOCD\n════════════════════════════════════════════════\n# UI — http://localhost:8080\nkubectl port-forward -n argocd svc/argocd-server 8080:80\n# Récupérer le mot de passe admin :\nkubectl -n argocd get secret argocd-initial-admin-secret \\\n  -o jsonpath=\"{.data.password}\" | base64 -d \u0026\u0026 echo\n\n# Argo Rollouts Dashboard — http://localhost:3100\nkubectl port-forward -n argo-rollouts svc/argo-rollouts-dashboard 3100:3100\n\n    ════════════════════════════════════════════════\n DÉMARRAGE RAPIDE\n════════════════════════════════════════════════\nmake port-forwards   # Lance tous les port-forwards en arrière-plan\nmake status          # État des pods par namespace\n\n",
      "type": "string"
    },
    "app_namespace": {
      "value": "demo-app",
      "type": "string"
    },
    "argocd_admin_password_cmd": {
      "value": "kubectl -n argocd get secret argocd-initial-admin-secret -o jsonpath='{.data.password}' | base64 -d \u0026\u0026 echo",
      "type": "string"
    },
    "cluster_name": {
      "value": "terraform-kube",
      "type": "string"
    },
    "cluster_nodes": {
      "value": [
        "terraform-kube"
      ],
      "type": [
        "tuple",
        [
          "string"
        ]
      ]
    },
    "git_repo_url": {
      "value": "",
      "type": "string"
    },
    "grafana_admin_password": {
      "value": "admin",
      "type": "string",
      "sensitive": true
    }
  },

                "namespace": "demo-app",
                "notes": "",
                "revision": 1,
                "values": "{\"analysis\":{\"count\":3,\"enabled\":true,\"failureLimit\":1,\"interval\":\"30s\",\"latencyP99Threshold\":\"1.0\",\"prometheusAddress\":\"http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090\",\"successRateThreshold\":\"0.90\"},\"app\":{\"colorHex\":\"#1a6cf5\",\"colorName\":\"blue\",\"features\":[\"Interface de base\",\"Authentification utilisateur\",\"Dashboard principal\"],\"gradientEnd\":\"#0d3fa3\",\"gradientStart\":\"#1a6cf5\",\"message\":\"Version 1.0 — Production\",\"version\":\"v1.0.0\"},\"image\":{\"pullPolicy\":\"IfNotPresent\",\"repository\":\"nginx\",\"tag\":\"1.25-alpine\"},\"ingress\":{\"annotations\":{\"nginx.ingress.kubernetes.io/proxy-body-size\":\"8m\"},\"className\":\"nginx\",\"enabled\":true,\"host\":\"demo-app.local\"},\"replicaCount\":2,\"rollout\":{\"autoPromotionEnabled\":false,\"previewReplicaCount\":1,\"scaleDownDelaySeconds\":60},\"service\":{\"port\":80}}",
                "version": "1.0.0"
              }
            ],
